# ╔══════════════════════════════════════════════════════════════════╗
# ║                  AI FRAMEWORK — CONFIGURATION                   ║
# ║                                                                  ║
# ║  This is the ONLY file you need to edit.                        ║
# ║  All settings here flow through to every module automatically.  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Target URLs ────────────────────────────────────────────────────
# Comma-separated list of URLs for the agent to test
TARGET_URLS=https://bold.pro

# ── Browser ────────────────────────────────────────────────────────
# HEADLESS: true = run silently | false = watch the browser
HEADLESS=false

# Browser type: chromium | firefox | webkit
BROWSER=chromium

# How many exploration steps per URL
MAX_STEPS=1

# Page navigation timeout in milliseconds
PAGE_TIMEOUT=60000

# ── Browser Stealth (fixes ERR_HTTP2_PROTOCOL_ERROR on strict sites) ──
# Spoof a real browser user-agent so the site doesn't block Playwright
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36

# Viewport size
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# Locale and timezone — some sites block non-matching combos
LOCALE=en-US
TIMEZONE=America/New_York

# ── Ollama / AI ────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_READ_TIMEOUT=300
OLLAMA_CONNECT_TIMEOUT=5
OLLAMA_RETRIES=1

# ── Reporting ──────────────────────────────────────────────────────
ALLURE_RESULTS_DIR=allure-results
ALLURE_REPORT_DIR=allure-report
BUG_REPORTS_DIR=bug_reports
SCREENSHOTS_DIR=screenshots
TC_FILE=generated_test_cases.xlsx
